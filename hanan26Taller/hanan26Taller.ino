// --- Reloj de secuenciador estable (fix BPM) ---------------------------------
// Antes el tempo se clockeaba con micros() (Timer0). Con pitch al minimo las
// voces nunca terminan de sonar, la ISR de audio se alarga, pierde overflows de
// Timer0 y micros() corre lento -> el patron entero se ralentizaba.
// Solucion: contamos el tiempo dentro de la propia ISR de audio, que jamas se
// pierde un tick.
// Tasa real de la ISR: Timer2 con prescaler /32 (el comentario del setup dice
// "/8" pero los bits CS=011 son /32) y OCR2A=50 -> 16MHz/32/51 = 9804 Hz.
// micros() de este firmware corre a 64 unidades por us real (Timer0 a /1).
// Para que audioclock iguale a ese micros() y los valores de taptempo den el
// mismo BPM: 64e6 / 9804 = 6528 unidades por muestra de audio.
volatile uint32_t audioclock = 0;
const uint16_t AUDIOCLOCK_STEP = 6528; // unidades micros() por muestra de audio

// Lectura atomica del contador de 32 bits (la ISR lo escribe byte a byte).
uint32_t readAudioClock() {
  uint32_t v;
  uint8_t s = SREG;
  cli();
  v = audioclock;
  SREG = s;
  return v;
}
